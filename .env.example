# ══════════════════════════════════════════════════════════
#  حساباتي ERP — Environment Variables
#  cp .env.example .env  ثم عدّل القيم
# ══════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────
APP_NAME="حساباتي ERP"
APP_VERSION="1.0.0"
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── Database (Supabase PostgreSQL Direct Connection) ───────
# Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://vvipolsrcgtanyvrfpuo.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── API ────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
# Comma-separated or JSON array
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://nassarfm.github.io"]

# ── Security ───────────────────────────────────────────────
SECRET_KEY=change-this-to-64-char-random-string-in-production

# ── Idempotency ────────────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400       # 24 hours
IDEMPOTENCY_BACKEND=db              # db | redis (redis not required for MVP)
# REDIS_URL=redis://localhost:6379/0

# ── Background Jobs ────────────────────────────────────────
SCHEDULER_ENABLED=false             # enable when modules are ready
SCHEDULER_TIMEZONE=Asia/Riyadh

# ── Audit ──────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_INCLUDE_REQUEST_BODY=true
AUDIT_INCLUDE_RESPONSE_BODY=false   # too verbose for prod

# ── Railway ────────────────────────────────────────────────
PORT=8000
